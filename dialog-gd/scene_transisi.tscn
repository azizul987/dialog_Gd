[sub_resource type="Shader" id="Shader_qx1o2"]
code = "shader_type canvas_item;
render_mode unshaded;

uniform sampler2D screen_texture :
	hint_screen_texture,
	repeat_disable,
	filter_linear;

uniform vec2 screen_resolution = vec2(320.0, 288.0);

uniform float brightness = 0.02;
uniform float contrast = 1.08;
uniform float saturation = 1.12;

uniform vec3 shadow_tint = vec3(0.96, 0.98, 1.04);
uniform vec3 highlight_tint = vec3(1.05, 1.02, 0.96);

uniform float vignette_strength = 0.18;
uniform float vignette_softness = 0.75;

uniform float grain_strength = 0.018;
uniform float chromatic_strength = 0.45;
uniform float sharpen_strength = 0.18;


float random_noise(vec2 uv) {
	return fract(sin(dot(uv, vec2(12.9898, 78.233))) * 43758.5453);
}


vec3 apply_saturation(vec3 col, float amount) {
	float gray = dot(col, vec3(0.299, 0.587, 0.114));
	return mix(vec3(gray), col, amount);
}


vec3 apply_sharpen(vec2 uv, vec3 col) {
	vec2 texel = 1.0 / screen_resolution;

	vec3 up = texture(screen_texture, uv + vec2(0.0, -texel.y)).rgb;
	vec3 down = texture(screen_texture, uv + vec2(0.0, texel.y)).rgb;
	vec3 left = texture(screen_texture, uv + vec2(-texel.x, 0.0)).rgb;
	vec3 right = texture(screen_texture, uv + vec2(texel.x, 0.0)).rgb;

	vec3 blur = (up + down + left + right) * 0.25;
	return mix(col, col + (col - blur), sharpen_strength);
}


void fragment() {
	vec2 uv = SCREEN_UV;
	vec2 center_uv = uv - 0.5;

	vec2 chroma_offset = center_uv * chromatic_strength / screen_resolution;

	float r = texture(screen_texture, uv + chroma_offset).r;
	float g = texture(screen_texture, uv).g;
	float b = texture(screen_texture, uv - chroma_offset).b;

	vec3 col = vec3(r, g, b);

	col = apply_sharpen(uv, col);

	col += brightness;
	col = (col - 0.5) * contrast + 0.5;
	col = apply_saturation(col, saturation);

	float luminance = dot(col, vec3(0.299, 0.587, 0.114));
	vec3 tint = mix(shadow_tint, highlight_tint, luminance);
	col *= tint;

	float dist = distance(uv, vec2(0.5));
	float vignette = smoothstep(vignette_softness, vignette_softness - vignette_strength, dist);
	col *= vignette;

	float grain = random_noise(uv * screen_resolution + TIME * 60.0);
	col += (grain - 0.5) * grain_strength;

	col = clamp(col, 0.0, 1.0);

	COLOR = vec4(col, 1.0);
}"

